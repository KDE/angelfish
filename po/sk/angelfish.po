msgid "Use smooth scrolling"
msgstr "Používať plynulé posúvanie"

#: src/settings/SettingsGeneral.qml:70
#, kde-format
msgid ""
"Scrolling is smoother and will not stop suddenly when you stop scrolling. "
"Requires app restart to take effect."
msgstr ""
"Posúvanie je plynulejšie a nezastaví sa náhle, keď prestanete posúvať. "
"Vyžaduje reštart aplikácie, aby sa to prejavilo."

#: src/settings/SettingsGeneral.qml:79
#, kde-format
